# Amplify Hosting (amplify.yml → web/api-config.js)

API_BASE_URL=https://YOUR_API_ID.execute-api.ap-southeast-1.amazonaws.com

# Must match SAM parameter EditRosterSecret (min 8 chars). Never commit the real value in git.
EDIT_ROSTER_KEY=

# Optional. First Wednesday (6 May 2026) maps to this roster name; leave empty to default to Pang Yong Xian.
SERIES_ANCHOR_NAME=Pang Yong Xian
