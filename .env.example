# Amplify Hosting (amplify.yml → web/api-config.js)

API_BASE_URL=https://YOUR_API_ID.execute-api.ap-southeast-1.amazonaws.com

# Cognito Hosted UI domain from SAM output CognitoHostedUiDomain.
COGNITO_DOMAIN=https://YOUR_PREFIX.auth.ap-southeast-1.amazoncognito.com

# Cognito app client from SAM output CognitoUserPoolClientId.
COGNITO_CLIENT_ID=

# Cognito user pool region (e.g. ap-southeast-1).
COGNITO_REGION=

# Optional. First Wednesday (6 May 2026) maps to this roster name; leave empty to default to Pang Yong Xian.
SERIES_ANCHOR_NAME=Pang Yong Xian
